{
  "global": {
    "background": "#2E2E2E",
    "caret": "#FFFFFF",
    "foreground": "#d6d6d6",
    "invisibles": "#404040",
    "lineHighlight": "#333435",
    "selection": "#5A647E",
    "findHighlight": "#FFE792",
    "findHighlightForeground": "#000000",
    "selectionBorder": "#5A647E",
    "activeGuide": "#9D550FB0",
    "bracketsForeground": "#F8F8F2A5",
    "bracketsOptions": "underline",
    "bracketContentsForeground": "#F8F8F2A5",
    "bracketContentsOptions": "underline",
    "tagsOptions": "stippled_underline"
  },
  "tokenColors": [
    {
      "settings": {
        "foreground": "#797979"
      },
      "scope": "comment",
      "name": "Comment"
    },
    {
      "settings": {
        "foreground": "#e5b567"
      },
      "scope": "string",
      "name": "String"
    },
    {
      "settings": {
        "foreground": "#9e86c8"
      },
      "scope": "constant.numeric",
      "name": "Number"
    },
    {
      "settings": {
        "foreground": "#9e86c8"
      },
      "scope": "constant.language",
      "name": "Built-in constant"
    },
    {
      "settings": {
        "foreground": "#9e86c8"
      },
      "scope": [
        "constant.character",
        "constant.other"
      ],
      "name": "User-defined constant"
    },
    {
      "settings": {
        "foreground": "#E87D3E"
      },
      "scope": "variable.other.readwrite.instance.coffee",
      "name": "Variable"
    },
    {
      "settings": {
        "foreground": "#b4c973"
      },
      "scope": "entity.name.type.class.coffee",
      "name": "Entity name"
    },
    {
      "settings": {
        "foreground": "#b05279"
      },
      "scope": "keyword",
      "name": "Keyword"
    },
    {
      "settings": {
        "foreground": "#b05279"
      },
      "scope": "storage",
      "name": "Storage"
    },
    {
      "settings": {
        "foreground": "#6c99bb",
        "fontStyle": "italic"
      },
      "scope": "storage.type",
      "name": "Storage type"
    },
    {
      "settings": {
        "foreground": "#b4c973",
        "fontStyle": "underline"
      },
      "scope": "entity.name.class",
      "name": "Class name"
    },
    {
      "settings": {
        "foreground": "#b4c973",
        "fontStyle": "italic underline"
      },
      "scope": "entity.other.inherited-class",
      "name": "Inherited class"
    },
    {
      "settings": {
        "foreground": "#b4c973"
      },
      "scope": "entity.name.function",
      "name": "Function name"
    },
    {
      "settings": {
        "foreground": "#E87D3E",
        "fontStyle": "italic"
      },
      "scope": "variable.parameter",
      "name": "Function argument"
    },
    {
      "settings": {
        "foreground": "#b05279"
      },
      "scope": "entity.name.tag",
      "name": "Tag name"
    },
    {
      "settings": {
        "foreground": "#b4c973"
      },
      "scope": "entity.other.attribute-name",
      "name": "Tag attribute"
    },
    {
      "settings": {
        "foreground": "#6c99bb"
      },
      "scope": "support.function",
      "name": "Library function"
    },
    {
      "settings": {
        "foreground": "#6c99bb"
      },
      "scope": "support.constant",
      "name": "Library constant"
    },
    {
      "settings": {
        "foreground": "#6c99bb",
        "fontStyle": "italic"
      },
      "scope": [
        "support.type",
        "support.class"
      ],
      "name": "Library class/type"
    },
    {
      "settings": {
        "foreground": "#F8F8F0",
        "background": "#b05279"
      },
      "scope": "invalid",
      "name": "Invalid"
    },
    {
      "settings": {
        "foreground": "#F8F8F0",
        "background": "#9e86c8"
      },
      "scope": "invalid.deprecated",
      "name": "Invalid deprecated"
    },
    {
      "settings": {
        "foreground": "#cfcfcf"
      },
      "scope": "meta.structure.dictionary.json string.quoted.double.json",
      "name": "JSON String"
    },
    {
      "settings": {
        "foreground": "#767676"
      },
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "name": "diff.header"
    },
    {
      "settings": {
        "foreground": "#b05279"
      },
      "scope": "markup.deleted",
      "name": "diff.deleted"
    },
    {
      "settings": {
        "foreground": "#b4c973"
      },
      "scope": "markup.inserted",
      "name": "diff.inserted"
    },
    {
      "settings": {
        "foreground": "#E5B567"
      },
      "scope": "markup.changed",
      "name": "diff.changed"
    },
    {
      "settings": {
        "foreground": "#9e86c8A0"
      },
      "scope": "constant.numeric.line-number.find-in-files - match"
    },
    {
      "settings": {
        "foreground": "#E5B567"
      },
      "scope": "entity.name.filename.find-in-files"
    }
  ]
}